# Copy to .env.local and fill in. NEVER commit .env.local.
# Supabase project settings → API.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. Must NOT have a NEXT_PUBLIC_ prefix and must never
# be used in a Client Component (Aturan Keras #4).
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the app (e.g. http://localhost:3000 in dev).
NEXT_PUBLIC_SITE_URL=
